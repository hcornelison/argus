{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Rest": {
        "Url": "http://0.0.0.0:8080",
        "Protocols": "Http1"
      },
      "Grpc": {
        "Url": "http://0.0.0.0:8081",
        "Protocols": "Http2"
      }
    }
  },
  "ConnectionStrings": {
    "Argus": "Server=localhost,1433;Database=Argus;User Id=sa;Password=Your_password123;TrustServerCertificate=True"
  },
  "Database": {
    "MigrateOnStartup": true
  },
  "Retention": {
    "Days": 7
  },
  "Ingest": {
    "ApiKeys": [ "dev-agent-key-001" ]
  },
  "Cors": {
    "Origins": [ "http://localhost:4200" ]
  }
}
