<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.argus.herald</string>

    <!-- Adjust the path to wherever herald is published. -->
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/argus-herald/Argus.Herald</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/usr/local/argus-herald</string>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/var/log/argus-herald.log</string>
    <key>StandardErrorPath</key>
    <string>/var/log/argus-herald.log</string>
</dict>
</plist>
