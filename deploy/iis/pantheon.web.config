<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS config for the pantheon SPA.
  - Reverse-proxies /api and /hubs/* to the styx Windows Service so the app is same-origin
    (requires the IIS "Application Request Routing" + "URL Rewrite" modules, with ARR proxy
    enabled at the server level, and the "WebSocket Protocol" feature for SignalR).
  - Falls back to index.html for client-side routes.
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- Forward API + SignalR hub traffic to styx (Kestrel service on :8080). -->
        <rule name="ProxyToStyx" stopProcessing="true">
          <match url="^(api|hubs)(/.*)?$" />
          <action type="Rewrite" url="http://localhost:8080/{R:0}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_PROTO" value="{MapScheme:{HTTPS}}" />
          </serverVariables>
        </rule>

        <!-- SPA fallback: serve index.html for non-file, non-directory requests. -->
        <rule name="AngularRoutes" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
      <rewriteMaps>
        <rewriteMap name="MapScheme">
          <add key="on" value="https" />
          <add key="off" value="http" />
        </rewriteMap>
      </rewriteMaps>
    </rewrite>

    <!-- Don't cache index.html so deploys are picked up immediately. -->
    <caching>
      <profiles>
        <add extension=".html" policy="DisableCache" />
      </profiles>
    </caching>

    <staticContent>
      <!-- Ensure correct MIME types for modern web assets. -->
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".webmanifest" />
      <mimeMap fileExtension=".webmanifest" mimeType="application/manifest+json" />
    </staticContent>
  </system.webServer>
</configuration>
